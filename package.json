{
  "name": "lead-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "build": "tsc && tsc-esm-fix",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "migrate:dev": "knex migrate:latest --knexfile ./src/infrastructure/database/knexfile.ts",
    "migrate:prod": "node node_modules/.bin/knex migrate:latest --env production --knexfile ./dist/src/infrastructure/database/knexfile.js",
    "migrate:make": "tsx node_modules/knex/bin/cli.js migrate:make --knexfile src/infrastructure/database/knexfile.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.3.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/knex": "^0.16.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0",
    "jest": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.11",
    "tsc-esm-fix": "^3.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "inversify": "^8.1.0",
    "knex": "^3.2.10",
    "pg": "^8.21.0"
  }
}
